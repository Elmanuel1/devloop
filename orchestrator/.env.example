# ---- Poller Config ----
WATCH_POLL_INTERVAL_SEC=10
MAX_POLL_WORKERS=5

# ---- Webhook Server ----
WEBHOOK_PORT=9400
WEBHOOK_SECRET=                    # GitHub webhook secret (optional, for signature verification)

# ---- State Backend ----
# STATE_BACKEND=file               # "file" (default) or "sqlite"
# STATE_DIR=                       # override state directory (default: ./orchestrator/.orchestrator)

# ---- Slack ----
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# ---- Atlassian (Jira + Confluence) ----
ATLASSIAN_SITE=
ATLASSIAN_EMAIL=
ATLASSIAN_TOKEN=

# ---- GitHub ----
# gh CLI uses GITHUB_TOKEN from env or gh auth login
# GITHUB_TOKEN=
