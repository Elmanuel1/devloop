# Docker Compose Environment Variables
# Copy this file to .env or springboot_local.env and fill in your values

# ========================================
# PostgreSQL (local development)
# ========================================
POSTGRES_DB=tosspaper
POSTGRES_USER=
POSTGRES_PASSWORD=

# ========================================
# Redis
# ========================================
REDIS_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0

# ========================================
# Temporal
# ========================================
TEMPORAL_VERSION=1.25.2
TEMPORAL_UI_VERSION=2.31.2

# Temporal database connection (use postgres container for local, RDS for remote)
TEMPORAL_DB_HOST=postgres
TEMPORAL_DB_PORT=5432
TEMPORAL_DB_USER=
TEMPORAL_DB_PASSWORD=

# ========================================
# Database (Spring Boot application)
# ========================================
DATABASE_URL=jdbc:postgresql://localhost:5432/tosspaper
DATABASE_USERNAME=
DATABASE_PASSWORD=

# ========================================
# AWS
# ========================================
AWS_REGION=us-west-2
AWS_S3_BUCKET_NAME=tosspaper-email-attachments

# For local development with LocalStack
# SQS_ENDPOINT=http://localhost:4566
# AWS_S3_ENDPOINT=http://localhost:4566
# AWS_S3_PATH_STYLE=true

# ========================================
# QuickBooks Integration
# ========================================
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=
# Sandbox URLs (for development)
QUICKBOOKS_DISCOVERY_URL=https://developer.api.intuit.com/.well-known/openid_sandbox_configuration
QUICKBOOKS_API_BASE_URL=https://sandbox-quickbooks.api.intuit.com/v3/company
# Production URLs
# QUICKBOOKS_DISCOVERY_URL=https://developer.api.intuit.com/.well-known/openid_configuration
# QUICKBOOKS_API_BASE_URL=https://quickbooks.api.intuit.com/v3/company

# Sync interval (seconds) - default 1800 (30 min), 3600 for production
QUICKBOOKS_SYNC_INTERVAL_SECONDS=1800

# ========================================
# Integration Encryption
# ========================================
INTEGRATION_ENCRYPTION_KEY=

# ========================================
# AI / OpenAI
# ========================================
AI_PROVIDER=reducto
AI_API_KEY=
OPENAI_API_KEY=

# ========================================
# Email / Mailgun
# ========================================
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=

# ========================================
# Frontend
# ========================================
FRONTEND_BASE_URL=http://localhost:3000

# ========================================
# GitHub Container Registry (for deployment)
# ========================================
GHCR_TOKEN=

# ========================================
# RDS IAM Auth (production only)
# ========================================
RDS_IAM_AUTH_ENABLED=false
