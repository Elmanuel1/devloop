# =============================================================================
# Terraform .gitignore
# =============================================================================

# Local .terraform directories
**/.terraform/*

# .tfstate files (state stored in S3)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Lock files (commit .terraform.lock.hcl for reproducible builds)
# .terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# tfvars files - safe to commit (only contain infrastructure IDs, not secrets)
# Secrets are stored in AWS Secrets Manager

# Plan files
*.tfplan
tfplan

# CLI configuration files
.terraformrc
terraform.rc
